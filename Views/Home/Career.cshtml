@{
    ViewData["Title"] = "Career Explorer";
    ViewData["Description"] = "Explore career paths linked to different courses and institutions in Nigeria.";
}

<header class="bg-surface-container-lowest border-b border-outline-variant shadow-sm sticky top-0 z-50">
<div class="flex justify-between items-center w-full px-margin-desktop py-4 max-w-container-max mx-auto">
<div class="flex items-center gap-8">
<a href="/" class="text-headline-sm font-bold text-secondary">AdmissionFinder</a>
<nav class="hidden md:flex items-center gap-6">
<a class="text-body-md text-on-surface-variant hover:text-secondary" href="/">Explore schools</a>
<a class="text-body-md text-on-surface-variant hover:text-secondary" href="/cutoff">Check cut-off</a>
<a class="text-body-md text-on-surface-variant hover:text-secondary" href="/compare">Compare</a>
<a class="text-body-md text-secondary font-bold border-b-2 border-secondary pb-1" href="/career">Career guide</a>
</nav>
</div>
<div class="flex items-center gap-4">
<a class="text-body-md text-on-surface-variant hover:text-secondary" href="/subjects">Subjects</a>
</div>
</div>
</header>

<main class="max-w-container-max mx-auto px-margin-desktop py-10">
<div class="mb-8">
<p class="text-label-md text-secondary uppercase tracking-wide mb-2">Career Guide</p>
<h1 class="text-headline-lg md:text-display-md text-primary font-bold mb-3">Explore career paths</h1>
<p class="text-body-lg text-on-surface-variant">Discover which courses lead to which careers, earning potential, and professional bodies in Nigeria.</p>
</div>

<div class="grid gap-8 lg:grid-cols-5">
<!-- Selector -->
<div class="lg:col-span-2 bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm">
<div class="space-y-4">
<div>
<label class="font-label-md text-label-md text-primary mb-1 block">Select a Course</label>
<select id="courseSelect" class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:outline-none focus:ring-2 focus:ring-secondary/40 font-body-md">
<option value="">Choose a course...</option>
</select>
</div>
<button id="viewBtn" class="w-full bg-secondary text-white py-3 rounded-lg font-label-md text-label-md hover:bg-primary transition-colors shadow-sm">
Explore Careers
</button>
</div>
</div>

<!-- Result -->
<div class="lg:col-span-3" id="resultArea">
<div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-8 shadow-sm flex flex-col items-center justify-center min-h-[400px] text-center">
<span class="material-symbols-outlined text-6xl text-outline-variant mb-4">rocket_launch</span>
<h2 class="text-headline-md text-primary mb-2">Select a course</h2>
<p class="text-body-md text-on-surface-variant">Choose a course to see its associated career paths, earning potential, and professional bodies.</p>
</div>
</div>

<!-- Browse all -->
<div class="lg:col-span-5 mt-4">
<h2 class="text-headline-sm text-primary mb-4">Browse all career paths</h2>
<div id="allCareers" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3"></div>
</div>
</div>
</main>

@section Scripts {
    <script>
        (function () {
            var AF = window.AdmissionFinder;
            var courseSelect = document.getElementById("courseSelect");
            var viewBtn = document.getElementById("viewBtn");
            var resultArea = document.getElementById("resultArea");
            var allCareers = document.getElementById("allCareers");

            AF.courses.forEach(function (c) {
                var opt = document.createElement("option");
                opt.value = c.id;
                opt.textContent = c.name + " (" + c.degree + ")";
                courseSelect.appendChild(opt);
            });

            // Handle ?course= query param
            var params = new URLSearchParams(window.location.search);
            var presetCourse = params.get("course");
            if (presetCourse) {
                courseSelect.value = presetCourse;
                showResult(presetCourse);
            }

            function showResult(courseId) {
                var course = AF.getCourse(courseId);
                var careers = AF.careers[courseId];
                var jamb = AF.jambSubjects[courseId];
                var olevel = AF.olevelReqs[courseId];

                if (!course || !careers) {
                    resultArea.innerHTML = '<div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-8 shadow-sm flex flex-col items-center justify-center min-h-[400px] text-center"><p class="text-body-md text-on-surface-variant">No career data for this course.</p></div>';
                    return;
                }

                resultArea.innerHTML =
                    '<div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm">' +
                    '<h2 class="text-headline-lg text-primary font-bold mb-1">' + course.name + '</h2>' +
                    '<p class="text-body-sm text-on-surface-variant mb-6">' + course.degree + ' &bull; ' + course.duration + ' years</p>' +
                    '<div class="space-y-4">' +
                    careers.map(function (cr) {
                        return '<div class="bg-surface-container-low rounded-xl p-5 border-l-4 ' +
                            (cr.demand === "High" ? 'border-success' : 'border-[#b45309]') + '">' +
                            '<div class="flex items-start justify-between mb-2">' +
                            '<h3 class="font-headline-sm text-headline-sm text-primary">' + cr.title + '</h3>' +
                            '<span class="chip ' + (cr.demand === "High" ? "chip-up" : "chip-flat") + '">' + cr.demand + ' demand</span>' +
                            '</div>' +
                            '<div class="grid grid-cols-2 gap-4 mt-3">' +
                            '<div><p class="text-label-sm text-on-surface-variant">Earnings</p><p class="font-semibold text-primary">' + cr.earnings + '</p></div>' +
                            (cr.bodies.length ? '<div><p class="text-label-sm text-on-surface-variant">Professional Bodies</p><div class="flex flex-wrap gap-1 mt-1">' + cr.bodies.map(function (b) { return '<span class="chip chip-flat">' + b + '</span>'; }).join("") + '</div></div>' : '') +
                            '</div></div>';
                    }).join("") +
                    '</div>' +
                    '<div class="flex gap-3 mt-6">' +
                    '<a href="/subjects" class="border border-outline-variant text-primary px-5 py-2 rounded-lg text-label-md hover:bg-surface-container transition-colors">View subject requirements</a>' +
                    '<a href="/recommendations?score=200&olevel=Mathematics,English,Physics" class="bg-secondary text-white px-5 py-2 rounded-lg text-label-md hover:bg-primary transition-colors">Check your matches</a>' +
                    '</div></div>';
            }

            viewBtn.addEventListener("click", function () {
                if (courseSelect.value) showResult(courseSelect.value);
            });
            courseSelect.addEventListener("change", function () {
                if (this.value) showResult(this.value);
            });

            // Browse all careers
            allCareers.innerHTML = AF.courses.map(function (c) {
                var careers = AF.careers[c.id];
                if (!careers) return "";
                return '<div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-5 hover:shadow-md transition-all cursor-pointer" onclick="window.location.href=\'/career?course=' + c.id + '\'">' +
                    '<h3 class="font-headline-sm text-headline-sm text-primary mb-2">' + c.name + '</h3>' +
                    '<div class="space-y-1">' +
                    careers.slice(0, 2).map(function (cr) {
                        return '<div class="flex items-center justify-between text-body-sm"><span>' + cr.title + '</span><span class="chip ' + (cr.demand === "High" ? "chip-up" : "chip-flat") + ' text-[10px]">' + cr.demand + '</span></div>';
                    }).join("") +
                    (careers.length > 2 ? '<p class="text-label-sm text-secondary">+' + (careers.length - 2) + ' more</p>' : '') +
                    '</div></div>';
            }).filter(function (s) { return s; }).join("");
        })();
    </script>
}
