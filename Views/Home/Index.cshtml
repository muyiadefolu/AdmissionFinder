@{
    ViewData["Title"] = "Find Your Academic Path";
    ViewData["Description"] = "Enter your UTME score and O'level subjects to receive transparent recommendations across Nigerian institutions.";
}

<!-- Top Navigation Bar -->
<header class="bg-surface-container-lowest border-b border-outline-variant shadow-sm sticky top-0 z-50">
<div class="flex justify-between items-center w-full px-margin-desktop py-4 max-w-container-max mx-auto">
<div class="flex items-center gap-8">
<a href="/" class="text-headline-sm font-bold text-secondary">AdmissionFinder</a>
<nav class="hidden md:flex items-center gap-6">
<a class="text-body-md text-secondary font-bold border-b-2 border-secondary pb-1" href="/">Explore schools</a>
<a class="text-body-md text-on-surface-variant hover:text-secondary" href="/cutoff">Check cut-off</a>
<a class="text-body-md text-on-surface-variant hover:text-secondary" href="/compare">Compare</a>
<a class="text-body-md text-on-surface-variant hover:text-secondary" href="/career">Career guide</a>
</nav>
</div>
<div class="flex items-center gap-4">
<a class="text-body-md text-on-surface-variant hover:text-secondary" href="/subjects">Subjects</a>
<a class="text-body-md text-on-surface-variant hover:text-secondary" href="/institutions">Institutions</a>
</div>
</div>
</header>

<main class="relative min-h-screen">
<div class="absolute top-0 right-0 -z-10 opacity-20 pointer-events-none">
<svg fill="none" height="600" viewbox="0 0 600 600" width="600" xmlns="http://www.w3.org/2000/svg">
<circle cx="450" cy="150" fill="url(#paint0_radial)" r="150"></circle>
<defs>
<radialgradient cx="0" cy="0" gradienttransform="translate(450 150) rotate(90) scale(150)" gradientunits="userSpaceOnUse" id="paint0_radial" r="1">
<stop stop-color="#316bf3"></stop>
<stop offset="1" stop-color="#316bf3" stop-opacity="0"></stop>
</radialgradient>
</defs>
</svg>
</div>

<!-- Hero Section -->
<section class="max-w-container-max mx-auto px-margin-desktop py-stack-lg flex flex-col md:flex-row items-center gap-16 min-h-[600px]">
<div class="w-full md:w-1/2 space-y-8">
<div>
<span class="text-on-tertiary-container font-label-sm text-label-sm tracking-widest uppercase mb-4 block">Your admission journey, simplified</span>
<h1 class="font-display-lg text-display-lg text-primary mb-6 leading-tight">
Find courses and schools that match your results.
</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant max-w-lg">
Enter your UTME score and O'level subjects to receive transparent recommendations across Nigerian institutions.
</p>
</div>

<!-- Score Input Form -->
<form id="recForm" class="glass-panel p-6 rounded-xl shadow-lg space-y-4" action="/recommendations" method="get" onsubmit="return submitRecForm(event)">
<div>
<label class="font-label-md text-label-md text-primary mb-1 block">Your JAMB/UTME Score</label>
<input id="scoreInput" name="score" type="number" min="0" max="400" placeholder="e.g. 221" required
class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:outline-none focus:ring-2 focus:ring-secondary/40 focus:border-secondary font-body-md" />
</div>
<div>
<label class="font-label-md text-label-md text-primary mb-1 block">O'level Credits (comma-separated)</label>
<input id="olevelInput" name="olevel" type="text" placeholder="e.g. Mathematics, English, Physics, Chemistry" required
class="w-full px-4 py-3 rounded-lg border border-outline-variant bg-surface focus:outline-none focus:ring-2 focus:ring-secondary/40 focus:border-secondary font-body-md" />
<p class="text-label-sm text-on-surface-variant mt-1">Enter subjects you have credit passes in</p>
</div>
<button type="submit" class="w-full bg-secondary text-white py-3 rounded-lg font-label-md text-label-md hover:bg-primary transition-colors shadow-sm">
Get Recommendations
</button>
</form>

<div class="flex items-center gap-6 pt-4">
<div class="flex -space-x-3">
<div class="w-10 h-10 rounded-full border-2 border-white bg-surface-container-high flex items-center justify-center overflow-hidden">
<img class="w-full h-full object-cover" data-alt="" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB4lMRSYxbirXJmKo9h5MNlowRm-NHizdK8QEcvVAd6l28O9XwSJbK_MZDGteWITP6JvobW8X3SJ2ICLcwSd_d2RaDWeZAmJ88W7XkrDiRCpLKRtQfwXAmS961kyFpH0qvFl-h7faXLaQzHTJb5eLfJ5SanNgZJ1N2FoqfjybxtMdPYKmjHiDPTd6BLui2363zJTo_o6v3t-jV-2NoqtFXjqESvUX8l5D2cNzaTHiMpAr5zoTrToLiuEg"/>
</div>
<div class="w-10 h-10 rounded-full border-2 border-white bg-surface-container-high flex items-center justify-center overflow-hidden">
<img class="w-full h-full object-cover" data-alt="" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDgzuzrKAgFuntpBRkx7CuQETh8z9J9PqjPXhwpjGLsfvwUPNkJpL5ULZo81VAaOLV5Xy31wqAHTVFGr8DWrKrym0pV7IZVWwSCA0atm8rAz52llqgzqefCR1sjei_RY17ksS4_OP7DYyl56MeRdleW0QIOEj9wVXXfNU2KM21m83tOLap42OSFwAglFitYpSVa6nI1HGitBAnawl9Vjx4CitxLNT0x6AsXyfRpf4XwBOF9adWYbdSMVQ"/>
</div>
<div class="w-10 h-10 rounded-full border-2 border-white bg-primary text-white flex items-center justify-center font-label-sm text-[10px]">+2k</div>
</div>
<p class="font-label-sm text-label-sm text-on-surface-variant">
Joined by <span class="font-bold text-primary">2,400+ students</span> this week
</p>
</div>
</div>

<!-- Right: Preview -->
<div class="w-full md:w-1/2">
<div class="bg-surface-container-low rounded-[2rem] p-stack-lg shadow-xl relative overflow-hidden">
<div class="absolute -top-12 -right-12 w-32 h-32 bg-secondary/10 rounded-full blur-2xl"></div>
<div class="relative z-10 space-y-6">
<div>
<span class="text-on-surface-variant font-label-sm text-label-sm block mb-2">Example eligibility summary</span>
<div class="flex items-baseline gap-3">
<span class="text-[80px] font-bold leading-none text-secondary">221</span>
<span class="text-on-surface-variant font-label-md text-label-md">UTME score</span>
</div>
</div>
<div class="space-y-4">
<div class="match-card bg-surface-container-lowest p-5 rounded-xl border-l-4 border-on-tertiary-container shadow-sm">
<div class="flex justify-between items-start mb-2">
<span class="text-[10px] font-bold tracking-widest text-on-tertiary-container uppercase">Strong Match</span>
<span class="material-symbols-outlined text-on-tertiary-container text-lg" style="font-variation-settings:'FILL'1">verified</span>
</div>
<h3 class="font-headline-sm text-headline-sm text-primary mb-1">Electrical Engineering</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">University of Lagos &bull; Cut-off: 220</p>
</div>
<div class="match-card bg-surface-container-lowest p-5 rounded-xl border-l-4 border-[#F59E0B] shadow-sm">
<div class="flex justify-between items-start mb-2">
<span class="text-[10px] font-bold tracking-widest text-[#F59E0B] uppercase">Borderline</span>
<span class="material-symbols-outlined text-[#F59E0B] text-lg">warning</span>
</div>
<h3 class="font-headline-sm text-headline-sm text-primary mb-1">Computer Engineering</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">University of Benin &bull; 3 points above cut-off</p>
</div>
</div>
</div>
</div>
</div>
</section>

<!-- Quick Links -->
<section class="bg-primary py-12">
<div class="max-w-container-max mx-auto px-margin-desktop">
<div class="grid grid-cols-2 md:grid-cols-4 gap-8">
<a href="/recommendations?score=200&olevel=Mathematics,English,Physics" class="text-center group">
<p class="text-[32px] font-bold leading-none mb-2 text-[#d6e3ff] group-hover:text-white transition-colors">170+</p>
<p class="text-label-sm text-label-sm uppercase tracking-wider text-on-primary-container">Universities</p>
</a>
<a href="/subjects" class="text-center group">
<p class="text-[32px] font-bold leading-none mb-2 text-[#d6e3ff] group-hover:text-white transition-colors">45k</p>
<p class="text-label-sm text-label-sm uppercase tracking-wider text-on-primary-container">Courses Listed</p>
</a>
<a href="/cutoff" class="text-center group">
<p class="text-[32px] font-bold leading-none mb-2 text-[#d6e3ff] group-hover:text-white transition-colors">98%</p>
<p class="text-label-sm text-label-sm uppercase tracking-wider text-on-primary-container">Accuracy Rate</p>
</a>
<a href="/career" class="text-center group">
<p class="text-[32px] font-bold leading-none mb-2 text-[#d6e3ff] group-hover:text-white transition-colors">1M+</p>
<p class="text-label-sm text-label-sm uppercase tracking-wider text-on-primary-container">Students Helped</p>
</a>
</div>
</div>
</section>

<!-- Feature Grid -->
<section class="max-w-container-max mx-auto px-margin-desktop py-24">
<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
<a href="/recommendations?score=200&olevel=Mathematics,English,Physics" class="md:col-span-2 bg-surface-container-high rounded-3xl p-stack-lg flex flex-col justify-between overflow-hidden relative group hover:shadow-lg transition-all">
<div class="relative z-10 max-w-md">
<h2 class="font-headline-lg text-headline-lg text-primary mb-4">Smart Institution Matching</h2>
<p class="font-body-md text-body-md text-on-surface-variant">Get ranked recommendations of institutions and courses you qualify for based on your UTME score and O'level results.</p>
</div>
<div class="mt-8 flex gap-3 text-secondary">
<span class="material-symbols-outlined text-3xl">auto_awesome</span>
<span class="font-label-md text-label-md self-end">Try it now &rarr;</span>
</div>
</a>
<a href="/compare" class="bg-secondary text-white rounded-3xl p-stack-lg flex flex-col justify-center items-center text-center hover:brightness-110 transition-all">
<span class="material-symbols-outlined text-6xl mb-4" style="font-variation-settings:'FILL'1">compare_arrows</span>
<h2 class="font-headline-md text-headline-md mb-2">Compare Schools</h2>
<p class="font-body-md text-body-md text-on-secondary-container">Side-by-side comparison of up to 3 institutions.</p>
</a>
<a href="/institutions" class="bg-surface-container-lowest border border-outline-variant rounded-3xl p-stack-lg flex flex-col justify-between hover:shadow-md transition-all">
<div>
<h3 class="font-headline-sm text-headline-sm text-primary mb-2">Institution Directory</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">Browse all Federal, State, Private universities, Polytechnics and Colleges of Education.</p>
</div>
<div class="flex justify-center py-4">
<span class="material-symbols-outlined text-5xl text-secondary">apartment</span>
</div>
</a>
<a href="/cutoff" class="bg-primary-container text-white rounded-3xl p-stack-lg flex items-center gap-6 hover:brightness-110 transition-all">
<div class="flex-1">
<h2 class="font-headline-md text-headline-md mb-2 text-primary-fixed">Check Cut-off Marks</h2>
<p class="font-body-sm text-body-sm text-on-primary-container">Verify if your score meets departmental cut-off requirements.</p>
</div>
<span class="material-symbols-outlined text-4xl text-secondary">fact_check</span>
</a>
<a href="/subjects" class="bg-surface-container rounded-3xl p-stack-lg flex flex-col justify-center items-center text-center hover:shadow-md transition-all">
<span class="material-symbols-outlined text-5xl text-secondary mb-3">menu_book</span>
<h3 class="font-headline-sm text-headline-sm text-primary mb-2">Subject Combinations</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">Check JAMB &amp; O'level requirements for any course.</p>
</a>
<a href="/career" class="bg-surface-variant rounded-3xl p-stack-lg flex flex-col justify-center items-center text-center hover:shadow-md transition-all">
<span class="material-symbols-outlined text-5xl text-secondary mb-3">rocket_launch</span>
<h3 class="font-headline-sm text-headline-sm text-primary mb-2">Career Guide</h3>
<p class="font-body-sm text-body-sm text-on-surface-variant">Explore career paths linked to your course of interest.</p>
</a>
</div>
</section>
</main>

<!-- Footer -->
<footer class="bg-surface-container border-t border-outline-variant">
<div class="w-full py-stack-lg px-margin-desktop flex flex-col md:flex-row justify-between items-center max-w-container-max mx-auto">
<div class="mb-6 md:mb-0 text-center md:text-left">
<span class="font-headline-sm text-headline-sm text-primary font-bold">AdmissionFinder</span>
<p class="font-body-sm text-body-sm text-on-surface-variant mt-2 max-w-xs">Empowering Nigerian students with data-driven academic decisions.</p>
</div>
<div class="flex flex-wrap justify-center gap-6 mb-6 md:mb-0">
<a class="font-body-sm text-body-sm text-on-surface-variant hover:text-secondary" href="/institutions">Institutions</a>
<a class="font-body-sm text-body-sm text-on-surface-variant hover:text-secondary" href="/compare">Compare</a>
<a class="font-body-sm text-body-sm text-on-surface-variant hover:text-secondary" href="/subjects">Subjects</a>
<a class="font-body-sm text-body-sm text-on-surface-variant hover:text-secondary" href="/career">Careers</a>
<a class="font-body-sm text-body-sm text-on-surface-variant hover:text-secondary" href="/cutoff">Cut-off</a>
</div>
<div class="text-right">
<p class="font-body-sm text-body-sm text-on-surface-variant">&copy; 2026 AdmissionFinder. All rights reserved.</p>
</div>
</div>
</footer>

@section Styles {
    <style>
        .glass-panel { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.3); }
    </style>
}

@section Scripts {
    <script>
        function submitRecForm(event) {
            event.preventDefault();
            var score = document.getElementById("scoreInput").value;
            var olevel = document.getElementById("olevelInput").value;
            if (score && olevel) {
                window.location.href = "/recommendations?score=" + encodeURIComponent(score) + "&olevel=" + encodeURIComponent(olevel);
            }
            return false;
        }
    </script>
}
