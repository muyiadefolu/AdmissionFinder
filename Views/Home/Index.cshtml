@section Styles {
    <style>
        .match-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .match-card:hover {
            transform: translateY(-2px);
            box-shadow: 0px 10px 15px -3px rgba(0, 0, 0, 0.1);
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
    </style>
}

@section Scripts {
    <script>
        var searchInput = document.querySelector('input');
        var glassPanel = document.querySelector('.glass-panel');

        if (searchInput) {
            searchInput.addEventListener('focus', function () {
                glassPanel.style.transform = 'scale(1.02)';
            });

            searchInput.addEventListener('blur', function () {
                glassPanel.style.transform = 'scale(1)';
            });
        }

        var observerOptions = { threshold: 0.1 };
        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('opacity-100', 'translate-y-0');
                    entry.target.classList.remove('opacity-0', 'translate-y-10');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.grid > div').forEach(function (item) {
            item.classList.add('transition-all', 'duration-700', 'opacity-0', 'translate-y-10');
            observer.observe(item);
        });
    </script>
}
