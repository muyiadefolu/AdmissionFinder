<!DOCTYPE html>
<html class="scroll-smooth" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] — AdmissionFinder</title>
    @if (ViewData["Description"] is string desc)
    {
        <meta name="description" content="@desc" />
    }
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface-bright": "#f8f9ff",
                        "surface-container-highest": "#d3e4fe",
                        "surface-container-high": "#dce9ff",
                        "inverse-surface": "#213145",
                        "inverse-primary": "#adc7f7",
                        "on-tertiary-fixed-variant": "#005236",
                        "on-primary-fixed": "#001b3c",
                        "surface-dim": "#cbdbf5",
                        "secondary-container": "#316bf3",
                        "on-error-container": "#93000a",
                        "error": "#ba1a1a",
                        "inverse-on-surface": "#eaf1ff",
                        "background": "#f8f9ff",
                        "on-secondary-fixed-variant": "#003ea8",
                        "surface-container-lowest": "#ffffff",
                        "error-container": "#ffdad6",
                        "on-secondary-container": "#fefcff",
                        "on-primary": "#ffffff",
                        "surface-container-low": "#eff4ff",
                        "surface-variant": "#d3e4fe",
                        "secondary": "#0051d5",
                        "primary": "#002045",
                        "on-background": "#0b1c30",
                        "on-surface-variant": "#43474e",
                        "on-secondary": "#ffffff",
                        "on-primary-container": "#86a0cd",
                        "primary-fixed": "#d6e3ff",
                        "primary-fixed-dim": "#adc7f7",
                        "on-tertiary-container": "#00b47d",
                        "on-surface": "#0b1c30",
                        "surface-tint": "#455f88",
                        "tertiary-fixed-dim": "#4edea3",
                        "outline": "#74777f",
                        "tertiary": "#002617",
                        "on-primary-fixed-variant": "#2d476f",
                        "secondary-fixed": "#dbe1ff",
                        "secondary-fixed-dim": "#b4c5ff",
                        "primary-container": "#1a365d",
                        "on-error": "#ffffff",
                        "on-tertiary-fixed": "#002113",
                        "outline-variant": "#c4c6cf",
                        "tertiary-fixed": "#6ffbbe",
                        "on-tertiary": "#ffffff",
                        "surface-container": "#e5eeff",
                        "surface": "#f8f9ff",
                        "tertiary-container": "#003e28",
                        "on-secondary-fixed": "#00174b",
                        "success": "#00754a",
                        "warn": "#b45309"
                    },
                    borderRadius: {
                        DEFAULT: "0.25rem",
                        lg: "0.5rem",
                        xl: "0.75rem",
                        full: "9999px"
                    },
                    spacing: {
                        "margin-desktop": "2.5rem",
                        "stack-md": "1rem",
                        "stack-lg": "2rem",
                        "stack-sm": "0.5rem",
                        "gutter": "1.5rem",
                        "margin-mobile": "1rem",
                        "container-max": "1280px"
                    },
                    fontFamily: {
                        "body-sm": ["Inter"],
                        "body-lg": ["Inter"],
                        "body-md": ["Inter"],
                        "headline-lg": ["Inter"],
                        "headline-md": ["Inter"],
                        "headline-sm": ["Inter"],
                        "label-md": ["Inter"],
                        "display-lg": ["Inter"],
                        "label-sm": ["Inter"]
                    },
                    fontSize: {
                        "body-sm": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                        "body-lg": ["18px", { "lineHeight": "28px", "fontWeight": "400" }],
                        "body-md": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "headline-lg": ["32px", { "lineHeight": "40px", "fontWeight": "700" }],
                        "headline-md": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
                        "headline-sm": ["20px", { "lineHeight": "28px", "fontWeight": "600" }],
                        "label-md": ["14px", { "lineHeight": "20px", "fontWeight": "600" }],
                        "display-lg": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "display-md": ["36px", { "lineHeight": "44px", "fontWeight": "700", "letterSpacing": "-0.02em" }],
                        "label-sm": ["12px", { "lineHeight": "16px", "fontWeight": "500" }]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        body {
            background-color: #f8f9ff;
            color: #0b1c30;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(ViewData["BodyClass"] is string bodyClass ? bodyClass : "font-body-md text-on-background")">
    @RenderBody()
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
